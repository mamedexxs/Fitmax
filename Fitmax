function admExportData(){
  const data = JSON.stringify({ users, exportedAt: new Date().toISOString() }, null, 2);
  const blob = new Blob([data], { type:'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `fitmax_users_${new Date().toISOString().split('T')[0]}.json`;
  a.click();
  admFeedback('✅ Dados exportados!');
}

function admResetAll(){
  if(!confirm('⚠️ ATENÇÃO: Isso vai deletar TODOS os usuários e dados. Tem certeza absoluta?')) return;
  if(!confirm('Segunda confirmação: APAGAR TUDO?')) return;
  users = [];
  localStorage.removeItem('fitmax_users');
  localStorage.removeItem('fitmax_current');
  admRenderStats(); admRenderUsers(users);
  admFeedback('✅ Tudo resetado');
}

function admLogout(){
  admAuthenticated = false;
  bnavGo('catalog');
}

function bnavGo(tab){
  document.querySelectorAll('.bnav-item').forEach(b => b.classList.remove('active'));
  if(tab === 'catalog'){
    setActiveNav('catalog');
    showPage('catalog');
  } else if(tab === 'murilo'){
    setActiveNav('murilo');
    showPage('murilo');
  } else if(tab === 'contato'){
    setActiveNav('contato');
    showPage('contato');
  } else if(tab === 'profile'){
    setActiveNav('profile');
    showPage('profile-page');
    renderProfile();
  } else if(tab === 'adm'){
    setActiveNav('adm');
    showPage('adm');
    admRenderStats();
    admRenderUsers(users);
  }
}

/* ══════════════════════════════════════
   INIT – runs on page load
══════════════════════════════════════ */
(function init(){

  // ── 1. Hide ALL pages immediately (before any display logic) ──
  document.querySelectorAll('.page').forEach(p => {
    p.classList.remove('active');
    p.style.display = 'none';
  });

  // ── 2. ADM secret: 5 taps on logo ──
  let logoTaps = 0, logoTimer;
  document.querySelector('.nav-logo')?.addEventListener('click', e => {
    e.preventDefault();
    logoTaps++;
    clearTimeout(logoTimer);
    logoTimer = setTimeout(() => { logoTaps = 0; }, 2000);
    if(logoTaps >= 5){
      logoTaps = 0;
      const admBtn = document.getElementById('bnav-adm');
      if(admBtn) admBtn.style.display = 'flex';
      admOpenLogin();
    }
  });

  // ── 3. Route based on login state ──
  if(currentUser){
    // Logged in → show app
    document.getElementById('nav-name').textContent = currentUser.name.split(' ')[0];
    document.body.classList.add('logged-in');
    document.getElementById('navbar').style.display    = 'flex';
    document.getElementById('bottom-nav').style.display = 'flex';
    document.getElementById('chat-fab').style.display  = 'flex';
    showPage('catalog');
    setActiveNav('catalog');
    showPushToastIfNeeded();
    setTimeout(() => {
      if(deferredPrompt && !localStorage.getItem('fitmax_install_dismissed'))
        document.getElementById('install-banner').style.display = 'flex';
    }, 6000);
  } else {
    // Not logged in → show auth only
    document.getElementById('navbar').style.display    = 'none';
    document.getElementById('bottom-nav').style.display = 'none';
    document.getElementById('chat-fab').style.display  = 'none';
    document.body.classList.remove('logged-in');
    const authPage = document.getElementById('page-auth');
    authPage.classList.add('active');
    authPage.style.display = 'flex';
  }
})();


