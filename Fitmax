<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<title>FitMax – Treinos Profissionais</title>
<meta name="description" content="FitMax – Treinos personalizados com IA. Acesse planos de musculação e treinamento funcional."/>
<link rel="manifest" href="manifest.json"/>
<meta name="theme-color" content="#e60000"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="FitMax"/>
<link rel="apple-touch-icon" href="icons/icon-192.png"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
/* Prevent flash before JS runs */
.page { display: none !important; }
</style>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:#0d0d0d;color:#f0f0f0;font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}
button{cursor:pointer;font-family:inherit;border:none;background:none}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:#0d0d0d}
::-webkit-scrollbar-thumb{background:#e60000;border-radius:2px}

/* ── VARIABLES ── */
:root{
  --red:#e60000;
  --red2:#ff2222;
  --dark:#0d0d0d;
  --dark2:#141414;
  --dark3:#1a1a1a;
  --dark4:#222;
  --border:rgba(255,255,255,.07);
  --muted:#666;
  --muted2:#999;
  --white:#f0f0f0;
  --font-h:'Bebas Neue',sans-serif;
}

/* ════════════════════════════════════════
   PAGES / ROUTER
════════════════════════════════════════ */
.page{display:none !important}
.page.active{display:block !important}
#page-auth.active{display:flex !important}
#page-auth.active ~ #navbar{ display:none !important }

/* ════════════════════════════════════════
   AUTH PAGE
════════════════════════════════════════ */
#page-auth{
  min-height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(230,0,0,.08) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(230,0,0,.05) 0%, transparent 50%),
    #0d0d0d;
  padding:24px;
}

#page-auth.active{display:flex}

.auth-box{
  width:100%;
  max-width:420px;
  background:var(--dark2);
  border:1px solid rgba(255,255,255,.08);
  border-radius:16px;
  padding:clamp(32px,6vw,48px);
  box-shadow:0 32px 80px rgba(0,0,0,.6);
  position:relative;
  overflow:hidden;
}

.auth-box::before{
  content:'';
  position:absolute;
  top:0;left:0;right:0;
  height:3px;
  background:linear-gradient(90deg,var(--red),rgba(230,0,0,.3));
}

.auth-logo{
  font-family:var(--font-h);
  font-size:2.6rem;
  letter-spacing:.1em;
  text-align:center;
  margin-bottom:6px;
}
.auth-logo span{color:var(--red)}

.auth-tagline{
  text-align:center;
  font-size:.8rem;
  color:var(--muted2);
  letter-spacing:.15em;
  text-transform:uppercase;
  margin-bottom:36px;
}

.auth-tabs{
  display:flex;
  background:var(--dark3);
  border-radius:8px;
  padding:4px;
  margin-bottom:28px;
  gap:4px;
}

.auth-tab{
  flex:1;
  padding:10px;
  border-radius:6px;
  font-size:.85rem;
  font-weight:600;
  letter-spacing:.06em;
  text-transform:uppercase;
  color:var(--muted2);
  transition:.2s;
  text-align:center;
}

.auth-tab.active{
  background:var(--red);
  color:#fff;
}

.auth-form{display:none;flex-direction:column;gap:16px}
.auth-form.active{display:flex}

.form-group-auth{display:flex;flex-direction:column;gap:6px}

.form-group-auth label{
  font-size:.72rem;
  font-weight:700;
  letter-spacing:.15em;
  text-transform:uppercase;
  color:var(--muted2);
}

.auth-input{
  background:var(--dark3);
  border:1px solid rgba(255,255,255,.08);
  border-radius:8px;
  padding:13px 16px;
  color:var(--white);
  font-family:'DM Sans',sans-serif;
  font-size:.95rem;
  outline:none;
  transition:.2s;
  width:100%;
}

.auth-input::placeholder{color:rgba(255,255,255,.2)}
.auth-input:focus{border-color:var(--red);background:rgba(230,0,0,.05)}

.auth-btn{
  background:var(--red);
  color:#fff;
  padding:14px;
  border-radius:8px;
  font-family:var(--font-h);
  font-size:1.1rem;
  letter-spacing:.1em;
  text-transform:uppercase;
  transition:.2s;
  margin-top:4px;
  box-shadow:0 0 24px rgba(230,0,0,.3);
}

.auth-btn:hover{background:var(--red2);box-shadow:0 0 40px rgba(230,0,0,.5);transform:translateY(-1px)}

.auth-error{
  background:rgba(230,0,0,.1);
  border:1px solid rgba(230,0,0,.3);
  border-radius:6px;
  padding:10px 14px;
  font-size:.83rem;
  color:#ff6b6b;
  display:none;
}

.auth-error.show{display:block}

.auth-divider{
  text-align:center;
  font-size:.75rem;
  color:var(--muted);
  position:relative;
  margin:4px 0;
}

.auth-divider::before,.auth-divider::after{
  content:'';
  position:absolute;
  top:50%;
  width:40%;
  height:1px;
  background:var(--border);
}
.auth-divider::before{left:0}
.auth-divider::after{right:0}

/* ════════════════════════════════════════
   NAVBAR
════════════════════════════════════════ */
#navbar{
  position:fixed;
  top:0;left:0;right:0;
  z-index:200;
  height:64px;
  background:rgba(13,13,13,.95);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:center;
  padding-inline:clamp(16px,4vw,48px);
}

.nav-inner{
  width:100%;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.nav-logo{
  font-family:var(--font-h);
  font-size:1.6rem;
  letter-spacing:.1em;
}
.nav-logo span{color:var(--red)}

.nav-user{
  display:flex;
  align-items:center;
  gap:16px;
}

.nav-username{
  font-size:.82rem;
  font-weight:600;
  color:var(--muted2);
}
.nav-username strong{color:var(--white)}

.nav-logout{
  font-size:.75rem;
  font-weight:700;
  letter-spacing:.1em;
  text-transform:uppercase;
  color:var(--muted);
  border:1px solid var(--border);
  border-radius:6px;
  padding:7px 14px;
  transition:.2s;
}
.nav-logout:hover{border-color:var(--red);color:var(--red)}

/* ════════════════════════════════════════
   MAIN LAYOUT
════════════════════════════════════════ */
.main-content{
  padding-top:64px;
  min-height:100vh;
}

/* ════════════════════════════════════════
   CATALOG PAGE
════════════════════════════════════════ */
#page-catalog{background:var(--dark)}

.catalog-hero{
  background:
    linear-gradient(160deg,rgba(13,13,13,.97) 40%,rgba(13,13,13,.8)),
    url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1600&q=70') center/cover no-repeat;
  padding:clamp(48px,8vw,80px) clamp(16px,4vw,48px) clamp(32px,5vw,56px);
  border-bottom:1px solid var(--border);
}

.catalog-hero-inner{max-width:1200px;margin:0 auto}

.catalog-hello{
  font-size:.78rem;
  font-weight:700;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--red);
  display:flex;
  align-items:center;
  gap:10px;
  margin-bottom:16px;
}
.catalog-hello::before{content:'';width:28px;height:2px;background:var(--red)}

.catalog-title{
  font-family:var(--font-h);
  font-size:clamp(2.8rem,6vw,5rem);
  line-height:.95;
  text-transform:uppercase;
  letter-spacing:.03em;
  margin-bottom:12px;
}
.catalog-title span{color:var(--red)}

.catalog-sub{
  font-size:.97rem;
  color:var(--muted2);
  max-width:460px;
  line-height:1.65;
}

/* filter bar */
.filter-bar{
  background:var(--dark2);
  border-bottom:1px solid var(--border);
  padding:16px clamp(16px,4vw,48px);
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  position:sticky;
  top:64px;
  z-index:100;
}

.filter-label{
  font-size:.72rem;
  font-weight:700;
  letter-spacing:.15em;
  text-transform:uppercase;
  color:var(--muted);
  margin-right:4px;
}

.filter-chip{
  font-size:.78rem;
  font-weight:600;
  letter-spacing:.06em;
  text-transform:uppercase;
  padding:7px 16px;
  border-radius:20px;
  border:1px solid var(--border);
  color:var(--muted2);
  transition:.2s;
  background:transparent;
}

.filter-chip:hover{border-color:rgba(230,0,0,.4);color:var(--white)}
.filter-chip.active{background:var(--red);border-color:var(--red);color:#fff}

/* grid */
.catalog-grid-wrap{
  max-width:1200px;
  margin:0 auto;
  padding:40px clamp(16px,4vw,48px);
}

.catalog-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(320px,1fr));
  gap:24px;
}

/* workout card */
.workout-card{
  background:var(--dark2);
  border:1px solid var(--border);
  border-radius:14px;
  overflow:hidden;
  transition:transform .3s,border-color .3s,box-shadow .3s;
  cursor:pointer;
}

.workout-card:hover{
  transform:translateY(-5px);
  border-color:rgba(230,0,0,.3);
  box-shadow:0 16px 48px rgba(0,0,0,.5),0 0 0 1px rgba(230,0,0,.1);
}

.card-img{
  position:relative;
  height:200px;
  overflow:hidden;
}

.card-img img{
  width:100%;height:100%;
  object-fit:cover;
  transition:transform .5s;
  filter:brightness(.75) saturate(.9) contrast(1.1);
}

.workout-card:hover .card-img img{transform:scale(1.06)}

.card-img::after{
  content:'';
  position:absolute;
  bottom:0;left:0;right:0;
  height:60%;
  background:linear-gradient(to top,var(--dark2),transparent);
}

.card-freq{
  position:absolute;
  top:12px;left:14px;
  z-index:2;
  display:flex;
  align-items:center;
  gap:5px;
  background:rgba(0,0,0,.75);
  backdrop-filter:blur(8px);
  border-radius:20px;
  padding:5px 12px;
  font-size:.72rem;
  font-weight:700;
  letter-spacing:.08em;
}

.freq-dot{
  width:7px;height:7px;
  border-radius:50%;
  background:var(--red);
  box-shadow:0 0 6px var(--red);
  flex-shrink:0;
}

.card-level{
  position:absolute;
  top:12px;right:14px;
  z-index:2;
  font-size:.72rem;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
  padding:5px 12px;
  border-radius:20px;
}

.level-iniciante{background:rgba(74,222,128,.15);border:1px solid rgba(74,222,128,.3);color:#4ade80}
.level-intermediario{background:rgba(251,146,60,.15);border:1px solid rgba(251,146,60,.3);color:#fb923c}
.level-avancado{background:rgba(248,113,113,.15);border:1px solid rgba(248,113,113,.3);color:#f87171}

.card-icon-badge{
  position:absolute;
  bottom:14px;right:14px;
  z-index:2;
  width:40px;height:40px;
  background:rgba(230,0,0,.9);
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  box-shadow:0 4px 16px rgba(230,0,0,.4);
}

.card-body{padding:22px 20px 24px}

.card-title{
  font-family:var(--font-h);
  font-size:1.5rem;
  letter-spacing:.03em;
  text-transform:uppercase;
  margin-bottom:8px;
  line-height:1.1;
}

.card-meta{
  display:flex;
  align-items:center;
  gap:14px;
  margin-bottom:10px;
}

.card-meta-item{
  display:flex;
  align-items:center;
  gap:5px;
  font-size:.77rem;
  color:var(--muted2);
}

.meta-orange{color:#fb923c}

.card-desc{
  font-size:.87rem;
  color:var(--muted2);
  line-height:1.6;
  margin-bottom:20px;
}

.card-btn{
  width:100%;
  background:var(--red);
  color:#fff;
  padding:13px;
  border-radius:8px;
  font-family:var(--font-h);
  font-size:1rem;
  letter-spacing:.1em;
  text-transform:uppercase;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  transition:.2s;
}

.card-btn:hover{background:var(--red2);box-shadow:0 0 20px rgba(230,0,0,.4)}

/* locked card state */
.card-locked .card-btn{
  background:rgba(230,0,0,.1);
  border:1px solid rgba(230,0,0,.25);
  color:var(--red);
}
.card-locked .card-btn:hover{background:rgba(230,0,0,.2)}

/* ════════════════════════════════════════
   MODAL – PIX PAYMENT
════════════════════════════════════════ */
.modal-overlay{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.85);
  backdrop-filter:blur(8px);
  z-index:500;
  display:none;
  align-items:center;
  justify-content:center;
  padding:24px;
}

.modal-overlay.open{display:flex}

.modal-box{
  background:var(--dark2);
  border:1px solid rgba(230,0,0,.2);
  border-radius:16px;
  width:100%;
  max-width:440px;
  padding:clamp(28px,5vw,40px);
  position:relative;
  box-shadow:0 0 80px rgba(230,0,0,.15);
  animation:modalIn .3s ease;
}

@keyframes modalIn{
  from{opacity:0;transform:scale(.95) translateY(12px)}
  to  {opacity:1;transform:scale(1) translateY(0)}
}

.modal-close{
  position:absolute;
  top:16px;right:16px;
  width:32px;height:32px;
  border-radius:50%;
  background:var(--dark3);
  color:var(--muted2);
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  transition:.2s;
}
.modal-close:hover{background:rgba(230,0,0,.15);color:var(--red)}

.modal-badge{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-size:.7rem;
  font-weight:700;
  letter-spacing:.15em;
  text-transform:uppercase;
  color:var(--red);
  background:rgba(230,0,0,.1);
  border:1px solid rgba(230,0,0,.2);
  border-radius:20px;
  padding:4px 12px;
  margin-bottom:14px;
}

.modal-title{
  font-family:var(--font-h);
  font-size:1.9rem;
  letter-spacing:.04em;
  text-transform:uppercase;
  margin-bottom:4px;
}
.modal-title span{color:var(--red)}

.modal-sub{font-size:.85rem;color:var(--muted2);margin-bottom:24px;line-height:1.6}

.modal-price-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  background:rgba(230,0,0,.06);
  border:1px solid rgba(230,0,0,.15);
  border-radius:10px;
  padding:16px 20px;
  margin-bottom:20px;
}

.modal-price-label{font-size:.78rem;color:var(--muted2);font-weight:600}
.modal-price-val{
  font-family:var(--font-h);
  font-size:2rem;
  color:var(--red);
  letter-spacing:.04em;
}

.pix-section-label{
  font-size:.7rem;
  font-weight:700;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:8px;
}

.pix-copy-row{
  display:flex;
  gap:8px;
  margin-bottom:16px;
}

.pix-input-show{
  flex:1;
  background:var(--dark3);
  border:1px solid var(--border);
  border-radius:7px;
  padding:11px 14px;
  font-size:.82rem;
  color:var(--muted2);
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  font-family:monospace;
}

.pix-copy-btn{
  flex-shrink:0;
  background:rgba(230,0,0,.1);
  border:1px solid rgba(230,0,0,.2);
  color:var(--red);
  border-radius:7px;
  padding:11px 18px;
  font-size:.75rem;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
  transition:.2s;
}
.pix-copy-btn:hover{background:rgba(230,0,0,.2)}
.pix-copy-btn.ok{background:rgba(74,222,128,.1);border-color:rgba(74,222,128,.3);color:#4ade80}

/* QR code placeholder */
.qr-center{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:8px;
  margin-bottom:20px;
}

.qr-box{
  width:110px;height:110px;
  background:var(--dark3);
  border:1px solid var(--border);
  border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
}

.qr-box svg{width:90px;height:90px;opacity:.4}

.qr-label{font-size:.68rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}

.modal-confirm-btn{
  width:100%;
  background:var(--red);
  color:#fff;
  padding:14px;
  border-radius:8px;
  font-family:var(--font-h);
  font-size:1.05rem;
  letter-spacing:.1em;
  text-transform:uppercase;
  transition:.2s;
  box-shadow:0 0 24px rgba(230,0,0,.25);
  margin-bottom:10px;
}
.modal-confirm-btn:hover{background:var(--red2);box-shadow:0 0 40px rgba(230,0,0,.4);transform:translateY(-1px)}

.modal-wpp-note{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  font-size:.77rem;
  color:var(--muted);
  text-align:center;
}

/* ════════════════════════════════════════
   WORKOUT DETAIL PAGE
════════════════════════════════════════ */
#page-workout{background:var(--dark)}

.workout-header{
  background:
    linear-gradient(160deg,rgba(13,13,13,.97) 40%,rgba(13,13,13,.75)),
    var(--wk-bg,url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1200&q=70')) center/cover no-repeat;
  padding:clamp(40px,7vw,72px) clamp(16px,4vw,48px) clamp(28px,4vw,48px);
  border-bottom:1px solid var(--border);
}

.workout-header-inner{max-width:1200px;margin:0 auto}

.back-btn{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-size:.78rem;
  font-weight:700;
  letter-spacing:.12em;
  text-transform:uppercase;
  color:var(--muted2);
  margin-bottom:24px;
  transition:.2s;
  padding:8px 16px;
  background:rgba(255,255,255,.05);
  border:1px solid var(--border);
  border-radius:6px;
}
.back-btn:hover{color:var(--white);border-color:rgba(255,255,255,.2)}

.wk-meta-row{
  display:flex;
  flex-wrap:wrap;
  align-items:center;
  gap:10px;
  margin-bottom:16px;
}

.wk-badge{
  font-size:.72rem;
  font-weight:700;
  letter-spacing:.1em;
  text-transform:uppercase;
  padding:5px 14px;
  border-radius:20px;
}

.wk-title{
  font-family:var(--font-h);
  font-size:clamp(2.4rem,5vw,4rem);
  line-height:.95;
  text-transform:uppercase;
  letter-spacing:.03em;
  margin-bottom:12px;
}
.wk-title span{color:var(--red)}

.wk-stats-row{
  display:flex;
  flex-wrap:wrap;
  gap:20px;
}

.wk-stat{
  display:flex;
  align-items:center;
  gap:7px;
  font-size:.85rem;
  color:var(--muted2);
}
.wk-stat .icon{font-size:1rem}
.wk-stat strong{color:var(--white)}

/* day sections */
.days-wrap{
  max-width:1200px;
  margin:0 auto;
  padding:clamp(24px,4vw,48px) clamp(16px,4vw,48px);
  display:flex;
  flex-direction:column;
  gap:24px;
}

.day-card{
  background:var(--dark2);
  border:1px solid var(--border);
  border-radius:12px;
  overflow:hidden;
}

.day-header{
  display:flex;
  align-items:center;
  gap:14px;
  padding:20px 24px;
  border-bottom:1px solid var(--border);
  background:var(--dark3);
}

.day-header-icon{
  width:38px;height:38px;
  background:rgba(230,0,0,.15);
  border:1px solid rgba(230,0,0,.25);
  border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
  flex-shrink:0;
}

.day-name{
  font-family:var(--font-h);
  font-size:1.3rem;
  letter-spacing:.06em;
