  setTimeout(()=>{ el.style.display='none'; }, 3000);
}

function admGiveFree(){
  const email = document.getElementById('adm-email-free').value.trim().toLowerCase();
  const plan  = document.getElementById('adm-plan-free').value;
  const u = users.find(u => u.email === email);
  if(!u){ admFeedback(`❌ Usuário não encontrado: ${email}`, false); return; }
  if(!u.unlocked) u.unlocked = [];

  if(plan === 'vitalicio'){
    // Grant full vitalicio: all workouts + IA chat + IA generator
    u.vitalicio = true;
    [...Array(30)].map((_,i)=>i+1).forEach(id => { if(!u.unlocked.includes(id)) u.unlocked.push(id); });
  } else if(plan === 'all'){
    [...Array(30)].map((_,i)=>i+1).forEach(id => { if(!u.unlocked.includes(id)) u.unlocked.push(id); });
  } else {
    const id=parseInt(plan); if(!u.unlocked.includes(id)) u.unlocked.push(id);
  }

  saveUsers();
  if(currentUser && currentUser.email === email){ currentUser = u; saveCurrentUser(); }
  document.getElementById('adm-email-free').value = '';
  admRenderStats(); admRenderUsers(users);
  admFeedback(`✅ ${plan === 'vitalicio' ? 'Vitalício COMPLETO' : 'Acesso'} liberado para ${u.name}!`);
}

function admRevoke(){
