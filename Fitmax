function requestPushPermission(){
  if(!('Notification' in window)){ showLogToast('⚠️ Navegador não suporta notificações'); return; }
  Notification.requestPermission().then(p=>{
    dismissPushToast();
    if(p==='granted'){
      showLogToast('🔔 Lembretes ativados!');
      setTimeout(()=>{ new Notification('FitMax 💪', { body:'Lembretes ativados! Bora treinar?', icon:'icons/icon-192.png' }); }, 1000);
    }
  });
}

function showPushToastIfNeeded(){
  if(!currentUser) return; // never show on auth page
  if(Notification.permission==='default' && !localStorage.getItem('fitmax_push_asked'))
    setTimeout(()=>{
      if(!currentUser) return; // double-check still logged in
      document.getElementById('push-toast').style.display='flex';
    }, 8000);
}

function dismissPushToast(){
  document.getElementById('push-toast').style.display='none';
  localStorage.setItem('fitmax_push_asked','1');
}

