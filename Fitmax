function calcStreak(history){
  if(!history.length) return 0;
  const days=[...new Set(history.map(h=>new Date(h.ts).toDateString()))].sort((a,b)=>new Date(b)-new Date(a));
  let streak=0, ref=new Date(); ref.setHours(0,0,0,0);
  for(const d of days){ const dd=new Date(d); dd.setHours(0,0,0,0); if((ref-dd)/86400000>1) break; streak++; ref=dd; }
  return streak;
}

