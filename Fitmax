/* ══════════════════════════════════════
   TIMER
══════════════════════════════════════ */
let timerInterval=null, timerTotal=90, timerLeft=90, timerRunning=false;
let timerSetsTotal=4, timerSetsDone=0;

function openTimer(exName, setsTotal, info){
  timerSetsTotal = setsTotal||4; timerSetsDone = 0;
  document.getElementById('timer-exercise-name').textContent = exName||'Exercício';
  document.getElementById('timer-sets-info').textContent = info||'';
  renderSeriesDots();
  setTimer(90);
  document.getElementById('timer-modal').classList.add('open');
}

function closeTimer(){ document.getElementById('timer-modal').classList.remove('open'); stopTimer(); }

function setTimer(s){ stopTimer(); timerTotal=s; timerLeft=s; timerRunning=false; updateTimerDisplay(); document.getElementById('timer-toggle-btn').textContent='▶ Iniciar'; document.getElementById('timer-status').textContent='Pausado'; }

function timerToggle(){ timerRunning ? stopTimer() : startTimer(); }

function startTimer(){
  if(timerLeft<=0) timerReset();
  timerRunning=true;
  document.getElementById('timer-toggle-btn').textContent='⏸ Pausar';
  document.getElementById('timer-status').textContent='Descansando...';
  timerInterval = setInterval(()=>{ timerLeft--; updateTimerDisplay(); if(timerLeft<=0){ stopTimer(); timerDone(); } }, 1000);
}

function stopTimer(){
  clearInterval(timerInterval); timerRunning=false;
  if(timerLeft>0){ document.getElementById('timer-toggle-btn').textContent='▶ Retomar'; document.getElementById('timer-status').textContent='Pausado'; }
}

function timerReset(){ stopTimer(); timerLeft=timerTotal; updateTimerDisplay(); document.getElementById('timer-toggle-btn').textContent='▶ Iniciar'; document.getElementById('timer-status').textContent='Pausado'; }

function timerDone(){
  document.getElementById('timer-status').textContent='✅ Pronto! Próxima série!';
  document.getElementById('timer-toggle-btn').textContent='▶ Iniciar';
  if(navigator.vibrate) navigator.vibrate([200,80,200]);
  playBeep();
  timerSetsDone++; renderSeriesDots();
  if(Notification.permission==='granted' && document.hidden)
    new Notification('FitMax – Descanso ok! 💪', { body:`Série ${timerSetsDone} de ${timerSetsTotal}`, icon:'icons/icon-192.png' });
}

function updateTimerDisplay(){
  const m=Math.floor(timerLeft/60).toString().padStart(2,'0'), s=(timerLeft%60).toString().padStart(2,'0');
  document.getElementById('timer-display').textContent=`${m}:${s}`;
  const circ=2*Math.PI*70; // r=70
  const offset = circ*(1-timerLeft/timerTotal);
  const circle = document.getElementById('timer-circle');
  circle.style.strokeDasharray = circ;
  circle.style.strokeDashoffset = offset;
  circle.style.stroke = timerLeft<=10?'#ff2222':timerLeft<=20?'#fb923c':'#e60000';
}

function renderSeriesDots(){
  const w=document.getElementById('timer-series-dots'); if(!w) return;
  w.innerHTML=Array.from({length:timerSetsTotal},(_,i)=>`<div style="width:26px;height:26px;border-radius:50%;background:${i<timerSetsDone?'#e60000':'rgba(255,255,255,.05)'};border:1.5px solid ${i<timerSetsDone?'#e60000':'rgba(255,255,255,.08)'};display:flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;color:${i<timerSetsDone?'#fff':'#333'};transition:.3s">${i<timerSetsDone?'✓':i+1}</div>`).join('');
}

function playBeep(){
  try{
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    [0,.15,.3].forEach(t=>{
      const o=ctx.createOscillator(), g=ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.frequency.value=880;
      g.gain.setValueAtTime(.3,ctx.currentTime+t);
      g.gain.exponentialRampToValueAtTime(.001,ctx.currentTime+t+.12);
      o.start(ctx.currentTime+t); o.stop(ctx.currentTime+t+.15);
    });
  }catch(e){}
}

